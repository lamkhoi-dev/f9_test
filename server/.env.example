# ========================================
# F9 Rendering API — Environment Variables
# ========================================

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Authentication ---
# Set to 'false' to allow unauthenticated access (guest mode, like original f9)
# Set to 'true' to require login for all AI endpoints
REQUIRE_AUTH=false
JWT_SECRET=your-jwt-secret-here-change-in-production

# --- Database (PostgreSQL) ---
# Railway provides DATABASE_URL automatically when you add a PostgreSQL service
# For local development, use individual variables instead:
DATABASE_URL=postgresql://postgres:password@localhost:5432/f9_rendering
# DB_NAME=f9_rendering
# DB_USER=postgres
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# --- Google Cloud / Vertex AI ---
# Option 1: Service Account JSON (for Railway — paste entire JSON content)
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}

# Option 2: File path (for local development)
# GOOGLE_APPLICATION_CREDENTIALS=./vertex-key.json

# GCP Project config
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# --- CORS ---
# Frontend URL (Railway/Vercel auto-detected, or specify manually)
# CORS_ORIGIN=https://your-frontend.vercel.app
