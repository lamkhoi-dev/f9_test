# Backend Environment Variables - Vertex AI Mode
# Không cần API Key — backend dùng Service Account JSON để xác thực.

# =============================================================
# CHO LOCAL DEVELOPMENT
# =============================================================
# Để trống — server sẽ tự tìm file vertex-key.json trong thư mục này.
# Hoặc trỏ thẳng tới file JSON nếu để file ở chỗ khác:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/vertex-key.json

# =============================================================
# CHO PRODUCTION (Railway / Cloud Run / VPS)
# =============================================================
# Dán toàn bộ nội dung file vertex-key.json vào đây (1 cục JSON dài):
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# GCP Project ID
GOOGLE_CLOUD_PROJECT=project-fdbf43b8-e8ee-4b6a-90a

# GCP Region
GOOGLE_CLOUD_LOCATION=us-central1

# Server port (Railway tự cấp, không cần đổi)
PORT=3001

# CORS — địa chỉ frontend được phép gọi vào backend
CORS_ORIGIN=https://f9render.com
